{{ 'printlab-design-grid.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign _pdg_collection = block.settings.collection_handle | default: collection.handle | default: ''
  assign _pdg_profile    = block.settings.profile_page_url  | default: '/pages/partners'
-%}

<style>
  #pdg-{{ block.id }} {
    --pdg-bg:          {{ block.settings.bg_color }};
    --pdg-sidebar-bg:  {{ block.settings.sidebar_bg }};
    --pdg-card-bg:     {{ block.settings.card_bg }};
    --pdg-ink:         {{ block.settings.ink_color }};
    --pdg-ink-soft:    {{ block.settings.ink_soft_color }};
    --pdg-ink-mute:    {{ block.settings.ink_mute_color }};
    --pdg-accent:      {{ block.settings.accent_color }};
    --pdg-rule:        {{ block.settings.rule_color }};
    --pdg-ed-bg:       {{ block.settings.ed_card_bg }};
    --pdg-chip-active: {{ block.settings.chip_active_color }};
  }
</style>

<div class="pdg-wrap"
     id="pdg-{{ block.id }}"
     data-pdg-block="{{ block.id }}"
     data-proxy-base="/apps/fabric-shop/api"
     data-collection="{{ _pdg_collection | escape }}"
     data-per-load="{{ block.settings.products_per_load }}"
     data-profile-url="{{ _pdg_profile | escape }}"
     data-editorial-interval="{{ block.settings.editorial_interval }}"
     data-show-topic="{{ block.settings.show_topic }}"
     data-show-theme="{{ block.settings.show_themes }}"
     data-show-suits-use="{{ block.settings.show_suits_use }}"
     data-show-occasion="{{ block.settings.show_occasions }}"
     data-show-scale="{{ block.settings.show_scale }}"
     data-show-subject="{{ block.settings.show_subject }}"
     data-show-palette="{{ block.settings.show_palette }}"
     data-show-studio="{{ block.settings.show_studio }}"
     data-show-editorial="{{ block.settings.show_editorial_cards }}"
     data-ed1-eyebrow="{{ block.settings.ed1_eyebrow | escape }}"
     data-ed1-title="{{ block.settings.ed1_title | escape }}"
     data-ed1-body="{{ block.settings.ed1_body | escape }}"
     data-ed1-cta-text="{{ block.settings.ed1_cta_text | escape }}"
     data-ed1-cta-url="{{ block.settings.ed1_cta_url }}"
     data-ed2-eyebrow="{{ block.settings.ed2_eyebrow | escape }}"
     data-ed2-title="{{ block.settings.ed2_title | escape }}"
     data-ed2-body="{{ block.settings.ed2_body | escape }}"
     data-ed2-cta-text="{{ block.settings.ed2_cta_text | escape }}"
     data-ed2-cta-url="{{ block.settings.ed2_cta_url }}">

  <div class="pdg-sidebar-backdrop" id="pdg-backdrop-{{ block.id }}"></div>

  <aside class="pdg-sidebar" id="pdg-sidebar-{{ block.id }}" aria-label="Filters">
    <button type="button" class="pdg-sidebar-close" aria-label="Close filters">&times;</button>
    <div class="pdg-sidebar-header">
      <span class="pdg-sidebar-title">Filters</span>
      <button type="button" class="pdg-clear-all" hidden>
        Clear all (<span class="pdg-clear-count">0</span>)
      </button>
    </div>
    <div class="pdg-filter-groups" id="pdg-filter-groups-{{ block.id }}"></div>
  </aside>

  <div class="pdg-main">
    <div class="pdg-active-chips" id="pdg-chips-{{ block.id }}" hidden></div>

    <div class="pdg-toolbar">
      <button type="button" class="pdg-filter-open-btn" aria-label="Open filters">Filters</button>
      <span class="pdg-count" id="pdg-count-{{ block.id }}">Loading&hellip;</span>
      <div class="pdg-toolbar-right">
        <select class="pdg-sort" id="pdg-sort-{{ block.id }}" aria-label="Sort by">
          <option value="newest">Newest</option>
          <option value="bestselling">Bestselling</option>
          <option value="az">A&ndash;Z</option>
          <option value="studio-az">Studio A&ndash;Z</option>
        </select>
      </div>
    </div>

    <div class="pdg-grid" id="pdg-grid-{{ block.id }}"></div>

    <div class="pdg-load-more" id="pdg-load-more-{{ block.id }}" hidden>
      <button type="button" class="pdg-load-btn" id="pdg-load-btn-{{ block.id }}">
        {{ block.settings.load_more_label | default: 'Load more designs' }}
      </button>
      <p class="pdg-load-count" id="pdg-load-count-{{ block.id }}"></p>
    </div>
  </div>
</div>

<script src="{{ 'printlab-design-grid.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Design Grid",
  "target": "section",
  "settings": [
    { "type": "header", "content": "Grid" },
    { "type": "text",     "id": "collection_handle",   "label": "Collection handle" },
    { "type": "url",      "id": "profile_page_url",    "label": "Partner profile page URL" },
    { "type": "range",    "id": "products_per_load",   "label": "Products per load",        "min": 12, "max": 48, "step": 12, "default": 24 },
    { "type": "text",     "id": "load_more_label",     "label": "Load more label",          "default": "Load more designs" },
    { "type": "checkbox", "id": "show_badges",         "label": "Show New / Bestseller badges", "default": true },

    { "type": "header", "content": "Filters" },
    { "type": "checkbox", "id": "show_topic",    "label": "Show Topic",              "default": true },
    { "type": "checkbox", "id": "show_themes",   "label": "Show Themes",             "default": true },
    { "type": "checkbox", "id": "show_suits_use","label": "Show Suits use",          "default": true },
    { "type": "checkbox", "id": "show_occasions","label": "Show Occasions",          "default": true },
    { "type": "checkbox", "id": "show_scale",    "label": "Show Scale",              "default": true },
    { "type": "checkbox", "id": "show_subject",  "label": "Show Subject search",     "default": true },
    { "type": "checkbox", "id": "show_palette",  "label": "Show Palette",            "default": true },
    { "type": "checkbox", "id": "show_studio",   "label": "Show Studio search",      "default": true },

    { "type": "header", "content": "Editorial cards" },
    { "type": "checkbox", "id": "show_editorial_cards", "label": "Show editorial break cards", "default": true },
    { "type": "range",    "id": "editorial_interval",   "label": "Insert card every N tiles",  "min": 4, "max": 16, "step": 2, "default": 8 },

    { "type": "header", "content": "Editorial card 1" },
    { "type": "text",     "id": "ed1_eyebrow",  "label": "Eyebrow" },
    { "type": "text",     "id": "ed1_title",    "label": "Title" },
    { "type": "textarea", "id": "ed1_body",     "label": "Body" },
    { "type": "text",     "id": "ed1_cta_text", "label": "CTA label" },
    { "type": "url",      "id": "ed1_cta_url",  "label": "CTA link" },

    { "type": "header", "content": "Editorial card 2" },
    { "type": "text",     "id": "ed2_eyebrow",  "label": "Eyebrow" },
    { "type": "text",     "id": "ed2_title",    "label": "Title" },
    { "type": "textarea", "id": "ed2_body",     "label": "Body" },
    { "type": "text",     "id": "ed2_cta_text", "label": "CTA label" },
    { "type": "url",      "id": "ed2_cta_url",  "label": "CTA link" },

    { "type": "header", "content": "Colours" },
    { "type": "color", "id": "bg_color",         "label": "Page background",    "default": "#FAF8F3" },
    { "type": "color", "id": "sidebar_bg",        "label": "Sidebar background", "default": "#FFFFFF" },
    { "type": "color", "id": "card_bg",           "label": "Card background",    "default": "#F5F5F5" },
    { "type": "color", "id": "ink_color",         "label": "Primary text",       "default": "#1A1814" },
    { "type": "color", "id": "ink_soft_color",    "label": "Secondary text",     "default": "#5C564A" },
    { "type": "color", "id": "ink_mute_color",    "label": "Muted text",         "default": "#9A9285" },
    { "type": "color", "id": "accent_color",      "label": "Accent (sage)",      "default": "#5C7355" },
    { "type": "color", "id": "rule_color",        "label": "Borders",            "default": "#E8E3D8" },
    { "type": "color", "id": "ed_card_bg",        "label": "Editorial card bg",  "default": "#1A1814" },
    { "type": "color", "id": "chip_active_color", "label": "Active chip border", "default": "#5C7355" }
  ]
}
{% endschema %}

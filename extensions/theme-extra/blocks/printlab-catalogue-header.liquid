{{ 'printlab-catalogue-header.css' | asset_url | stylesheet_tag }}

<style>
  #plch-{{ block.id }} {
    --plch-bg:       {{ block.settings.bg_color }};
    --plch-ink:      {{ block.settings.ink_color }};
    --plch-ink-soft: {{ block.settings.ink_soft_color }};
    --plch-sage:     {{ block.settings.sage_color }};
    --plch-rule:     {{ block.settings.rule_color }};
  }
</style>

<div class="plch-wrap" id="plch-{{ block.id }}">
  <div class="plch-inner">

    {%- if block.settings.eyebrow != blank -%}
      <p class="plch-eyebrow">{{ block.settings.eyebrow | escape }}</p>
    {%- endif -%}

    {%- if block.settings.heading != blank -%}
      <h1 class="plch-title">{{ block.settings.heading | escape }}</h1>
    {%- endif -%}

    {%- if block.settings.subtitle != blank -%}
      <p class="plch-sub">{{ block.settings.subtitle | escape }}</p>
    {%- endif -%}

    {%- assign plch_shown = 0 -%}
    <div class="plch-stats">

      {%- if block.settings.show_stat1 -%}
        <div class="plch-stat">
          <strong class="plch-stat__num" data-plch-stat="designs">{{ block.settings.stat1_number | escape }}</strong>
          <span class="plch-stat__label">{{ block.settings.stat1_label | escape }}</span>
        </div>
        {%- assign plch_shown = plch_shown | plus: 1 -%}
      {%- endif -%}

      {%- if block.settings.show_stat2 -%}
        {%- if plch_shown > 0 -%}<div class="plch-divide" aria-hidden="true"></div>{%- endif -%}
        <div class="plch-stat">
          <strong class="plch-stat__num" data-plch-stat="studios">{{ block.settings.stat2_number | escape }}</strong>
          <span class="plch-stat__label">{{ block.settings.stat2_label | escape }}</span>
        </div>
        {%- assign plch_shown = plch_shown | plus: 1 -%}
      {%- endif -%}

      {%- if block.settings.show_stat3 -%}
        {%- if plch_shown > 0 -%}<div class="plch-divide" aria-hidden="true"></div>{%- endif -%}
        <div class="plch-stat">
          <strong class="plch-stat__num" data-plch-stat="newThisMonth">{{ block.settings.stat3_number | escape }}</strong>
          <span class="plch-stat__label">{{ block.settings.stat3_label | escape }}</span>
        </div>
        {%- assign plch_shown = plch_shown | plus: 1 -%}
      {%- endif -%}

      {%- if block.settings.show_stat4 -%}
        {%- if plch_shown > 0 -%}<div class="plch-divide" aria-hidden="true"></div>{%- endif -%}
        <div class="plch-stat">
          <strong class="plch-stat__num" data-plch-stat="collections">{{ block.settings.stat4_number | escape }}</strong>
          <span class="plch-stat__label">{{ block.settings.stat4_label | escape }}</span>
        </div>
      {%- endif -%}

    </div>

  </div>
</div>

<script>
(function () {
  var wrap = document.getElementById('plch-{{ block.id }}');
  if (!wrap) return;

  fetch('/apps/fabric-shop/api/printlab-stats')
    .then(function (r) { return r.ok ? r.json() : null; })
    .then(function (data) {
      if (!data) return;
      ['designs', 'studios', 'newThisMonth', 'collections'].forEach(function (key) {
        var el = wrap.querySelector('[data-plch-stat="' + key + '"]');
        if (el && data[key] != null) el.textContent = data[key];
      });
    })
    .catch(function () { /* keep static fallback values */ });
})();
</script>

{% schema %}
{
  "name": "PrintLab Catalogue Header",
  "target": "section",
  "settings": [
    { "type": "header", "content": "Content" },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "PrintLab · the catalogue"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Original prints, from independent studios."
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Hundreds of original designs from independent studios — printed on demand, on the base fabric of your choice. Filter by mood, scale, palette. Browse by studio."
    },

    { "type": "header", "content": "Stats", "info": "Fallback values shown before the live API responds. Use the toggles to choose which stats appear." },
    {
      "type": "checkbox",
      "id": "show_stat1",
      "label": "Show stat 1",
      "default": true
    },
    {
      "type": "text",
      "id": "stat1_number",
      "label": "Stat 1 — number (fallback)",
      "default": "847"
    },
    {
      "type": "text",
      "id": "stat1_label",
      "label": "Stat 1 — label",
      "default": "Original designs"
    },
    {
      "type": "checkbox",
      "id": "show_stat2",
      "label": "Show stat 2",
      "default": true
    },
    {
      "type": "text",
      "id": "stat2_number",
      "label": "Stat 2 — number (fallback)",
      "default": "62"
    },
    {
      "type": "text",
      "id": "stat2_label",
      "label": "Stat 2 — label",
      "default": "Independent studios"
    },
    {
      "type": "checkbox",
      "id": "show_stat3",
      "label": "Show stat 3",
      "default": true
    },
    {
      "type": "text",
      "id": "stat3_number",
      "label": "Stat 3 — number (fallback)",
      "default": "34"
    },
    {
      "type": "text",
      "id": "stat3_label",
      "label": "Stat 3 — label",
      "default": "New this month"
    },
    {
      "type": "checkbox",
      "id": "show_stat4",
      "label": "Show stat 4",
      "default": true
    },
    {
      "type": "text",
      "id": "stat4_number",
      "label": "Stat 4 — number (fallback)",
      "default": "12"
    },
    {
      "type": "text",
      "id": "stat4_label",
      "label": "Stat 4 — label",
      "default": "Curated collections"
    },

    { "type": "header", "content": "Colours" },
    { "type": "color", "id": "bg_color",       "label": "Background",        "default": "#FAF8F3" },
    { "type": "color", "id": "ink_color",       "label": "Heading / ink",     "default": "#1A1814" },
    { "type": "color", "id": "ink_soft_color",  "label": "Subtitle / labels", "default": "#5C564A" },
    { "type": "color", "id": "sage_color",      "label": "Eyebrow accent",    "default": "#5C7355" },
    { "type": "color", "id": "rule_color",      "label": "Dividers / border", "default": "#E8E3D8" }
  ]
}
{% endschema %}

{{ 'printlab-catalogue-header.css' | asset_url | stylesheet_tag }}

<style>
  #plch-{{ block.id }} {
    --plch-bg:       {{ block.settings.bg_color }};
    --plch-ink:      {{ block.settings.ink_color }};
    --plch-ink-soft: {{ block.settings.ink_soft_color }};
    --plch-sage:     {{ block.settings.sage_color }};
    --plch-rule:     {{ block.settings.rule_color }};
  }
</style>

<div class="plch-wrap" id="plch-{{ block.id }}"
  data-plch-endpoint="{{ block.settings.api_endpoint | escape }}">
  <div class="plch-inner">

    {%- if block.settings.eyebrow != blank -%}
      <p class="plch-eyebrow">{{ block.settings.eyebrow | escape }}</p>
    {%- endif -%}

    {%- if block.settings.heading != blank -%}
      <h1 class="plch-title">{{ block.settings.heading | escape }}</h1>
    {%- endif -%}

    {%- if block.settings.subtitle != blank -%}
      <p class="plch-sub">{{ block.settings.subtitle | escape }}</p>
    {%- endif -%}

    {%- assign _stats_shown = 0 -%}
    <div class="plch-stats">

      {%- if block.settings.show_stat1 -%}
        <div class="plch-stat">
          <strong class="plch-stat__num" data-plch-stat="designs" data-plch-api-key="{{ block.settings.stat1_api_key | escape }}">{{ block.settings.stat1_number | escape }}</strong>
          <span class="plch-stat__label">{{ block.settings.stat1_label | escape }}</span>
        </div>
        {%- assign _stats_shown = _stats_shown | plus: 1 -%}
      {%- endif -%}

      {%- if block.settings.show_stat2 -%}
        {%- if _stats_shown > 0 -%}<div class="plch-divide" aria-hidden="true"></div>{%- endif -%}
        <div class="plch-stat">
          <strong class="plch-stat__num" data-plch-stat="studios" data-plch-api-key="{{ block.settings.stat2_api_key | escape }}">{{ block.settings.stat2_number | escape }}</strong>
          <span class="plch-stat__label">{{ block.settings.stat2_label | escape }}</span>
        </div>
        {%- assign _stats_shown = _stats_shown | plus: 1 -%}
      {%- endif -%}

      {%- if block.settings.show_stat3 -%}
        {%- if _stats_shown > 0 -%}<div class="plch-divide" aria-hidden="true"></div>{%- endif -%}
        <div class="plch-stat">
          <strong class="plch-stat__num" data-plch-stat="newThisMonth" data-plch-api-key="{{ block.settings.stat3_api_key | escape }}">{{ block.settings.stat3_number | escape }}</strong>
          <span class="plch-stat__label">{{ block.settings.stat3_label | escape }}</span>
        </div>
        {%- assign _stats_shown = _stats_shown | plus: 1 -%}
      {%- endif -%}

      {%- if block.settings.show_stat4 -%}
        {%- if _stats_shown > 0 -%}<div class="plch-divide" aria-hidden="true"></div>{%- endif -%}
        <div class="plch-stat">
          <strong class="plch-stat__num" data-plch-stat="collections" data-plch-api-key="{{ block.settings.stat4_api_key | escape }}">{{ block.settings.stat4_number | escape }}</strong>
          <span class="plch-stat__label">{{ block.settings.stat4_label | escape }}</span>
        </div>
      {%- endif -%}

    </div>

  </div>
</div>

<script>
(function () {
  var wrap = document.getElementById('plch-{{ block.id }}');
  if (!wrap) return;

  var endpoint = (wrap.dataset.plchEndpoint || '').trim() || '/apps/fabric-shop/api/printlab-stats';

  fetch(endpoint)
    .then(function (r) { return r.ok ? r.json() : null; })
    .then(function (data) {
      if (!data) return;
      wrap.querySelectorAll('[data-plch-api-key]').forEach(function (el) {
        var key = el.dataset.plchApiKey;
        if (key && data[key] != null) el.textContent = data[key];
      });
    })
    .catch(function () { /* keep static fallback values */ });
})();
</script>

{% schema %}
{
  "name": "PrintLab Catalogue Header",
  "target": "section",
  "settings": [
    { "type": "header", "content": "Content" },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "PrintLab · the catalogue"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Original prints, from independent studios."
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Hundreds of original designs from independent studios — printed on demand, on the base fabric of your choice. Filter by mood, scale, palette. Browse by studio."
    },

    {
      "type": "header",
      "content": "Stats",
      "info": "Fallback values shown before the live API responds. Toggle each stat on or off independently."
    },
    {
      "type": "text",
      "id": "api_endpoint",
      "label": "Stats API endpoint",
      "default": "/apps/fabric-shop/api/printlab-stats",
      "info": "JSON endpoint that returns live stat values. Change per page — e.g. /apps/fabric-shop/api/partner-stats for Studios."
    },

    { "type": "header", "content": "Stat 1" },
    {
      "type": "checkbox",
      "id": "show_stat1",
      "label": "Show stat 1",
      "default": true
    },
    {
      "type": "text",
      "id": "stat1_number",
      "label": "Number (fallback)",
      "default": "847"
    },
    {
      "type": "text",
      "id": "stat1_label",
      "label": "Label",
      "default": "Original designs"
    },
    {
      "type": "text",
      "id": "stat1_api_key",
      "label": "API key",
      "default": "designs",
      "info": "Key in the API JSON response mapped to this stat."
    },

    { "type": "header", "content": "Stat 2" },
    {
      "type": "checkbox",
      "id": "show_stat2",
      "label": "Show stat 2",
      "default": true
    },
    {
      "type": "text",
      "id": "stat2_number",
      "label": "Number (fallback)",
      "default": "62"
    },
    {
      "type": "text",
      "id": "stat2_label",
      "label": "Label",
      "default": "Independent studios"
    },
    {
      "type": "text",
      "id": "stat2_api_key",
      "label": "API key",
      "default": "studios",
      "info": "Key in the API JSON response mapped to this stat."
    },

    { "type": "header", "content": "Stat 3" },
    {
      "type": "checkbox",
      "id": "show_stat3",
      "label": "Show stat 3",
      "default": true
    },
    {
      "type": "text",
      "id": "stat3_number",
      "label": "Number (fallback)",
      "default": "34"
    },
    {
      "type": "text",
      "id": "stat3_label",
      "label": "Label",
      "default": "New this month"
    },
    {
      "type": "text",
      "id": "stat3_api_key",
      "label": "API key",
      "default": "newThisMonth",
      "info": "Key in the API JSON response mapped to this stat."
    },

    { "type": "header", "content": "Stat 4" },
    {
      "type": "checkbox",
      "id": "show_stat4",
      "label": "Show stat 4",
      "default": true
    },
    {
      "type": "text",
      "id": "stat4_number",
      "label": "Number (fallback)",
      "default": "12"
    },
    {
      "type": "text",
      "id": "stat4_label",
      "label": "Label",
      "default": "Curated collections"
    },
    {
      "type": "text",
      "id": "stat4_api_key",
      "label": "API key",
      "default": "collections",
      "info": "Key in the API JSON response mapped to this stat."
    },

    { "type": "header", "content": "Colours" },
    { "type": "color", "id": "bg_color",       "label": "Background",        "default": "#FAF8F3" },
    { "type": "color", "id": "ink_color",       "label": "Heading / ink",     "default": "#1A1814" },
    { "type": "color", "id": "ink_soft_color",  "label": "Subtitle / labels", "default": "#5C564A" },
    { "type": "color", "id": "sage_color",      "label": "Eyebrow accent",    "default": "#5C7355" },
    { "type": "color", "id": "rule_color",      "label": "Dividers / border", "default": "#E8E3D8" }
  ]
}
{% endschema %}

{{ 'printlab-catalogue-header.css' | asset_url | stylesheet_tag }}

<style>
  #plch-{{ block.id }} {
    --plch-bg:       {{ block.settings.bg_color }};
    --plch-ink:      {{ block.settings.ink_color }};
    --plch-ink-soft: {{ block.settings.ink_soft_color }};
    --plch-sage:     {{ block.settings.sage_color }};
    --plch-rule:     {{ block.settings.rule_color }};
    --eyebrow-size:  {{ block.settings.eyebrow_font_size }}px;
  }
</style>

<div class="plch-wrap" id="plch-{{ block.id }}">
  <div class="plch-inner">

    {%- if block.settings.eyebrow != blank -%}
      <p class="plch-eyebrow">{{ block.settings.eyebrow | escape }}</p>
    {%- endif -%}

    {%- if block.settings.heading != blank -%}
      <h1 class="plch-title">{{ block.settings.heading | remove: '<p>' | remove: '</p>' }}</h1>
    {%- endif -%}

    {%- if block.settings.subtitle != blank -%}
      <p class="plch-sub">{{ block.settings.subtitle | escape }}</p>
    {%- endif -%}

    {%- assign plch_shown = 0 -%}
    <div class="plch-stats">

      {%- if block.settings.show_designs -%}
        <div class="plch-stat">
          <strong class="plch-stat__num" data-plch-stat="designs"><span class="plch-skel"></span></strong>
          <span class="plch-stat__label">{{ block.settings.designs_label | escape }}</span>
        </div>
        {%- assign plch_shown = plch_shown | plus: 1 -%}
      {%- endif -%}

      {%- if block.settings.show_studios -%}
        {%- if plch_shown > 0 -%}<div class="plch-divide" aria-hidden="true"></div>{%- endif -%}
        <div class="plch-stat">
          <strong class="plch-stat__num" data-plch-stat="studios"><span class="plch-skel"></span></strong>
          <span class="plch-stat__label">{{ block.settings.studios_label | escape }}</span>
        </div>
        {%- assign plch_shown = plch_shown | plus: 1 -%}
      {%- endif -%}

      {%- if block.settings.show_countries -%}
        {%- if plch_shown > 0 -%}<div class="plch-divide" aria-hidden="true"></div>{%- endif -%}
        <div class="plch-stat">
          <strong class="plch-stat__num" data-plch-stat="countries"><span class="plch-skel"></span></strong>
          <span class="plch-stat__label">{{ block.settings.countries_label | escape }}</span>
        </div>
        {%- assign plch_shown = plch_shown | plus: 1 -%}
      {%- endif -%}

      {%- if block.settings.show_collections -%}
        {%- if plch_shown > 0 -%}<div class="plch-divide" aria-hidden="true"></div>{%- endif -%}
        <div class="plch-stat">
          <strong class="plch-stat__num" data-plch-stat="collections"><span class="plch-skel"></span></strong>
          <span class="plch-stat__label">{{ block.settings.collections_label | escape }}</span>
        </div>
        {%- assign plch_shown = plch_shown | plus: 1 -%}
      {%- endif -%}

      {%- if block.settings.show_new_this_month -%}
        {%- if plch_shown > 0 -%}<div class="plch-divide" aria-hidden="true"></div>{%- endif -%}
        <div class="plch-stat">
          <strong class="plch-stat__num" data-plch-stat="newThisMonth"><span class="plch-skel"></span></strong>
          <span class="plch-stat__label">{{ block.settings.new_this_month_label | escape }}</span>
        </div>
      {%- endif -%}

    </div>

  </div>
</div>

<script>
(function () {
  var wrap = document.getElementById('plch-{{ block.id }}');
  if (!wrap) return;

  fetch('/apps/fabric-shop/api/printlab-stats')
    .then(function (r) { return r.ok ? r.json() : null; })
    .then(function (data) {
      if (!data) return;
      ['designs', 'studios', 'countries', 'collections', 'newThisMonth'].forEach(function (key) {
        var el = wrap.querySelector('[data-plch-stat="' + key + '"]');
        if (el && data[key] != null) el.textContent = data[key];
      });
    })
    .catch(function () {
      wrap.querySelectorAll('.plch-skel').forEach(function (s) { s.remove(); });
    });
})();
</script>

{% schema %}
{"name":"PrintLab Catalogue Header","target":"section","settings":[{"type":"header","content":"Content"},{"type":"text","id":"eyebrow","label":"Eyebrow","default":"PrintLab · the catalogue"},{"type":"range","id":"eyebrow_font_size","label":"Eyebrow font size","min":8,"max":20,"step":1,"unit":"px","default":13},{"type":"richtext","id":"heading","label":"Heading","default":"<p>Original prints, from <em>independent studios</em>.</p>"},{"type":"textarea","id":"subtitle","label":"Subtitle","default":"Hundreds of original designs from independent studios — printed on demand, on the base fabric of your choice. Filter by mood, scale, palette. Browse by studio."},{"type":"header","content":"Stats","info":"Toggle each stat on or off. Numbers load live from the API."},{"type":"checkbox","id":"show_designs","label":"Show Designs","default":true},{"type":"text","id":"designs_label","label":"Designs — label","default":"Original designs"},{"type":"checkbox","id":"show_studios","label":"Show Studios","default":true},{"type":"text","id":"studios_label","label":"Studios — label","default":"Independent studios"},{"type":"checkbox","id":"show_countries","label":"Show Countries","default":false},{"type":"text","id":"countries_label","label":"Countries — label","default":"Countries"},{"type":"checkbox","id":"show_collections","label":"Show Collections","default":true},{"type":"text","id":"collections_label","label":"Collections — label","default":"Curated collections"},{"type":"checkbox","id":"show_new_this_month","label":"Show New This Month","default":true},{"type":"text","id":"new_this_month_label","label":"New This Month — label","default":"New this month"},{"type":"header","content":"Colours"},{"type":"color","id":"bg_color","label":"Background","default":"#FAF8F3"},{"type":"color","id":"ink_color","label":"Heading / ink","default":"#1A1814"},{"type":"color","id":"ink_soft_color","label":"Subtitle / labels","default":"#5C564A"},{"type":"color","id":"sage_color","label":"Eyebrow accent","default":"#5C7355"},{"type":"color","id":"rule_color","label":"Dividers / border","default":"#E8E3D8"}]}
{% endschema %}

{%- liquid
  assign _est_h = 121
  if block.settings.utility_text != blank
    assign _est_h = 157
  endif
-%}
<style>body{padding-top:{{ _est_h }}px}.fs-chrome{position:fixed;top:0;left:0;right:0;z-index:1000;background:#FAF8F3;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;line-height:1.5}{%- if block.settings.hide_native_header -%}{{ block.settings.native_header_selector }}{display:none!important}{%- endif -%}</style>
{{ 'megamenu.css' | asset_url | stylesheet_tag }}
{%- liquid
  assign is_dp = false
  if customer
    for tag in customer.tags
      assign tag_lower = tag | downcase
      if tag_lower == 'partner_approved'
        assign is_dp = true
      endif
    endfor
  endif
  assign has_about_sub = false
  if block.settings.nav_about_sub_1_label != blank or block.settings.nav_about_sub_2_label != blank or block.settings.nav_about_sub_3_label != blank
    assign has_about_sub = true
  endif
-%}

<div class="fs-chrome" id="fs-chrome-{{ block.id }}">

{%- if block.settings.utility_text != blank -%}
<div class="fs-util-bar"><span>{{- block.settings.utility_text | escape -}}</span></div>
{%- endif -%}

<div class="fs-main-header">
  <div class="fs-main-header__inner">
    <a href="{{ routes.root_url }}" class="fs-logo" aria-label="{{ shop.name }}">
      {%- if block.settings.logo != blank -%}
        {{ block.settings.logo | image_url: width: 280 | image_tag: class: 'fs-logo__img', loading: 'eager', alt: shop.name }}
      {%- else -%}<h1 class="fs-logo__text">{{ shop.name }}</h1>{%- endif -%}
    </a>
    <div class="fs-search-wrap">
      <button class="fs-search-scope" type="button" aria-haspopup="listbox" aria-expanded="false">
        <span class="fs-search-scope__label">Designs</span>
        <svg class="fs-search-scope__chevron" width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 4l4 4 4-4"/></svg>
      </button>
      <ul class="fs-search-scope__drop" role="listbox" aria-label="Search scope">
        <li class="fs-search-scope__opt is-active" role="option" aria-selected="true" data-scope="designs" data-ph="Search fabrics, prints, designs…">Designs</li>
        <li class="fs-search-scope__opt" role="option" aria-selected="false" data-scope="designers" data-ph="Search by designer name…">Designers</li>
        <li class="fs-search-scope__opt" role="option" aria-selected="false" data-scope="studios" data-ph="Search by studio name…">Studios</li>
      </ul>
      <form class="fs-search-form" action="{{ routes.search_url }}" method="get" role="search">
        <input type="hidden" name="type" value="product">
        <div class="fs-search-input-wrap">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
          <input type="search" name="q" class="fs-search__input" placeholder="Search fabrics, prints, designs…" aria-label="Search" autocomplete="off">
        </div>
        <button type="submit" class="fs-search__btn" aria-label="Search"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg></button>
      </form>
    </div>
    <div class="fs-header-icons">
      <a href="{{ routes.account_url }}" class="fs-icon-btn" aria-label="Account"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></a>
      <a href="/pages/wishlist" class="fs-icon-btn" aria-label="Wishlist"><span class="fs-icon-badge" id="fs-wishlist-badge" style="display:none"></span><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></a>
      <a href="{{ routes.cart_url }}" class="fs-icon-btn" aria-label="Cart ({{ cart.item_count }} items)">{%- if cart.item_count > 0 -%}<span class="fs-icon-badge">{{ cart.item_count }}</span>{%- endif -%}<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg></a>
      {%- if is_dp -%}<span class="fs-icons-divider" aria-hidden="true"></span><a href="/apps/fabric-shop" class="fs-dp-chip" aria-label="Partner Studio">{{- customer.first_name | slice: 0 | upcase -}}{{- customer.last_name | slice: 0 | upcase -}}</a>{%- endif -%}
      <button class="fs-hamburger" aria-label="Menu" aria-expanded="false" aria-controls="fs-drawer"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg></button>
    </div>
  </div>
</div>

<nav class="fs-nav-bar" aria-label="Main navigation">
  <div class="fs-nav-bar__inner">
    <ul class="fs-nav" role="list">

{%- if block.settings.nav_1_label != blank -%}
<li class="fs-nav__item fs-nav__item--mega">
  <a href="{{ block.settings.nav_1_url | default: '#' }}" class="fs-nav__link" aria-haspopup="true" aria-expanded="false">{{- block.settings.nav_1_label | escape -}}<svg class="fs-nav__chevron" width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 4l4 4 4-4"/></svg></a>
  <div class="fs-mega-panel" role="region">
    <div class="fs-mega-panel__inner"><div class="fs-mega-grid">
      <div class="fs-mega-col fs-mega-col--browse">
        <p class="fs-mega-col__heading">Browse {{- block.settings.nav_1_label | escape -}}</p>
        <ul class="fs-mega-list" role="list">
          {%- for i in (1..4) -%}{%- assign l = 'nav_1_link_' | append: i | append: '_label' -%}{%- assign u = 'nav_1_link_' | append: i | append: '_url' -%}{%- if block.settings[l] != blank -%}<li><a href="{{ block.settings[u] | default: '#' }}" class="fs-mega-list__link">{{- block.settings[l] | escape -}}</a></li>{%- endif -%}{%- endfor -%}
        </ul>
      </div>
      <div class="fs-mega-col fs-mega-col--featured">
        <p class="fs-mega-col__heading">Featured this month</p>
        <ul class="fs-mega-featured" role="list">
          {%- for i in (1..3) -%}{%- assign fl = 'nav_1_feat_' | append: i | append: '_label' -%}{%- assign fu = 'nav_1_feat_' | append: i | append: '_url' -%}{%- if block.settings[fl] != blank -%}<li><a href="{{ block.settings[fu] | default: '#' }}" class="fs-mega-feat-item"><div class="fs-mega-feat-item__thumb"><div class="fs-mega-feat-item__placeholder"></div></div><div class="fs-mega-feat-item__text"><strong>{{- block.settings[fl] | escape -}}</strong></div></a></li>{%- endif -%}{%- endfor -%}
        </ul>
      </div>
      <div class="fs-mega-col fs-mega-col--cta fs-mega-cta--{{ block.settings.nav_1_cta_surface }}">
        {%- if block.settings.nav_1_cta_headline != blank -%}<h3 class="fs-mega-cta__headline">{{- block.settings.nav_1_cta_headline | escape -}}</h3>{%- endif -%}
        {%- if block.settings.nav_1_cta_body != blank -%}<p class="fs-mega-cta__body">{{- block.settings.nav_1_cta_body | escape -}}</p>{%- endif -%}
        {%- if block.settings.nav_1_cta_btn_label != blank -%}<a href="{{ block.settings.nav_1_cta_btn_url | default: '#' }}" class="fs-mega-cta__btn">{{- block.settings.nav_1_cta_btn_label | escape -}}</a>{%- endif -%}
      </div>
    </div></div>
  </div>
</li>
{%- endif -%}

{%- if block.settings.nav_2_label != blank -%}
<li class="fs-nav__item fs-nav__item--mega">
  <a href="{{ block.settings.nav_2_url | default: '#' }}" class="fs-nav__link" aria-haspopup="true" aria-expanded="false">{{- block.settings.nav_2_label | escape -}}<svg class="fs-nav__chevron" width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 4l4 4 4-4"/></svg></a>
  <div class="fs-mega-panel" role="region">
    <div class="fs-mega-panel__inner"><div class="fs-mega-grid">
      <div class="fs-mega-col fs-mega-col--browse">
        <p class="fs-mega-col__heading">Browse {{- block.settings.nav_2_label | escape -}}</p>
        <ul class="fs-mega-list" role="list">
          {%- for i in (1..4) -%}{%- assign l = 'nav_2_link_' | append: i | append: '_label' -%}{%- assign u = 'nav_2_link_' | append: i | append: '_url' -%}{%- if block.settings[l] != blank -%}<li><a href="{{ block.settings[u] | default: '#' }}" class="fs-mega-list__link">{{- block.settings[l] | escape -}}</a></li>{%- endif -%}{%- endfor -%}
        </ul>
      </div>
      <div class="fs-mega-col fs-mega-col--featured">
        <p class="fs-mega-col__heading">Featured this month</p>
        <ul class="fs-mega-featured" role="list">
          {%- for i in (1..3) -%}{%- assign fl = 'nav_2_feat_' | append: i | append: '_label' -%}{%- assign fu = 'nav_2_feat_' | append: i | append: '_url' -%}{%- if block.settings[fl] != blank -%}<li><a href="{{ block.settings[fu] | default: '#' }}" class="fs-mega-feat-item"><div class="fs-mega-feat-item__thumb"><div class="fs-mega-feat-item__placeholder"></div></div><div class="fs-mega-feat-item__text"><strong>{{- block.settings[fl] | escape -}}</strong></div></a></li>{%- endif -%}{%- endfor -%}
        </ul>
      </div>
      <div class="fs-mega-col fs-mega-col--cta fs-mega-cta--{{ block.settings.nav_2_cta_surface }}">
        {%- if block.settings.nav_2_cta_headline != blank -%}<h3 class="fs-mega-cta__headline">{{- block.settings.nav_2_cta_headline | escape -}}</h3>{%- endif -%}
        {%- if block.settings.nav_2_cta_body != blank -%}<p class="fs-mega-cta__body">{{- block.settings.nav_2_cta_body | escape -}}</p>{%- endif -%}
        {%- if block.settings.nav_2_cta_btn_label != blank -%}<a href="{{ block.settings.nav_2_cta_btn_url | default: '#' }}" class="fs-mega-cta__btn">{{- block.settings.nav_2_cta_btn_label | escape -}}</a>{%- endif -%}
      </div>
    </div></div>
  </div>
</li>
{%- endif -%}

{%- if block.settings.nav_3_label != blank -%}
<li class="fs-nav__item fs-nav__item--mega">
  <a href="{{ block.settings.nav_3_url | default: '#' }}" class="fs-nav__link" aria-haspopup="true" aria-expanded="false">{{- block.settings.nav_3_label | escape -}}<svg class="fs-nav__chevron" width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 4l4 4 4-4"/></svg></a>
  <div class="fs-mega-panel" role="region">
    <div class="fs-mega-panel__inner"><div class="fs-mega-grid">
      <div class="fs-mega-col fs-mega-col--browse">
        <p class="fs-mega-col__heading">Browse {{- block.settings.nav_3_label | escape -}}</p>
        <ul class="fs-mega-list" role="list">
          {%- for i in (1..4) -%}{%- assign l = 'nav_3_link_' | append: i | append: '_label' -%}{%- assign u = 'nav_3_link_' | append: i | append: '_url' -%}{%- if block.settings[l] != blank -%}<li><a href="{{ block.settings[u] | default: '#' }}" class="fs-mega-list__link">{{- block.settings[l] | escape -}}</a></li>{%- endif -%}{%- endfor -%}
        </ul>
        {%- if block.settings.nav_3_designer_link_1_label != blank or block.settings.nav_3_designer_link_2_label != blank -%}
        <div class="fs-mega-designer-block">
          <p class="fs-mega-designer-block__label">— For designers</p>
          <ul class="fs-mega-list" role="list">
            {%- if block.settings.nav_3_designer_link_1_label != blank -%}<li><a href="{{ block.settings.nav_3_designer_link_1_url | default: '#' }}" class="fs-mega-list__link fs-mega-list__link--aubergine">{{- block.settings.nav_3_designer_link_1_label | escape -}}</a></li>{%- endif -%}
            {%- if block.settings.nav_3_designer_link_2_label != blank -%}<li><a href="{{ block.settings.nav_3_designer_link_2_url | default: '#' }}" class="fs-mega-list__link fs-mega-list__link--aubergine">{{- block.settings.nav_3_designer_link_2_label | escape -}}</a></li>{%- endif -%}
          </ul>
        </div>
        {%- endif -%}
      </div>
      <div class="fs-mega-col fs-mega-col--featured">
        <p class="fs-mega-col__heading">Featured studios</p>
        <ul class="fs-mega-featured" role="list">
          {%- for i in (1..3) -%}{%- assign fl = 'nav_3_feat_' | append: i | append: '_label' -%}{%- assign fu = 'nav_3_feat_' | append: i | append: '_url' -%}{%- if block.settings[fl] != blank -%}<li><a href="{{ block.settings[fu] | default: '#' }}" class="fs-mega-feat-item"><div class="fs-mega-feat-item__thumb"><div class="fs-mega-feat-item__placeholder"></div></div><div class="fs-mega-feat-item__text"><strong>{{- block.settings[fl] | escape -}}</strong></div></a></li>{%- endif -%}{%- endfor -%}
        </ul>
      </div>
      <div class="fs-mega-col fs-mega-col--cta fs-mega-cta--{{ block.settings.nav_3_cta_surface }}">
        {%- if block.settings.nav_3_cta_headline != blank -%}<h3 class="fs-mega-cta__headline">{{- block.settings.nav_3_cta_headline | escape -}}</h3>{%- endif -%}
        {%- if block.settings.nav_3_cta_body != blank -%}<p class="fs-mega-cta__body">{{- block.settings.nav_3_cta_body | escape -}}</p>{%- endif -%}
        {%- if block.settings.nav_3_cta_btn_label != blank -%}<a href="{{ block.settings.nav_3_cta_btn_url | default: '#' }}" class="fs-mega-cta__btn">{{- block.settings.nav_3_cta_btn_label | escape -}}</a>{%- endif -%}
      </div>
    </div></div>
  </div>
</li>
{%- endif -%}

{%- if block.settings.nav_about_label != blank -%}
<li class="fs-nav__item{% if has_about_sub %} fs-nav__item--mini{% endif %}">
  <a href="{{ block.settings.nav_about_url | default: '#' }}" class="fs-nav__link"{% if has_about_sub %} aria-haspopup="true" aria-expanded="false"{% endif %}>{{- block.settings.nav_about_label | escape -}}{% if has_about_sub %}<svg class="fs-nav__chevron" width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 4l4 4 4-4"/></svg>{% endif %}</a>
  {%- if has_about_sub -%}
  <div class="fs-mini-panel" role="region">
    <ul class="fs-mega-list" role="list">
      {%- if block.settings.nav_about_sub_1_label != blank -%}<li><a href="{{ block.settings.nav_about_sub_1_url | default: '#' }}" class="fs-mega-list__link">{{- block.settings.nav_about_sub_1_label | escape -}}</a></li>{%- endif -%}
      {%- if block.settings.nav_about_sub_2_label != blank -%}<li><a href="{{ block.settings.nav_about_sub_2_url | default: '#' }}" class="fs-mega-list__link">{{- block.settings.nav_about_sub_2_label | escape -}}</a></li>{%- endif -%}
      {%- if block.settings.nav_about_sub_3_label != blank -%}<li><a href="{{ block.settings.nav_about_sub_3_url | default: '#' }}" class="fs-mega-list__link">{{- block.settings.nav_about_sub_3_label | escape -}}</a></li>{%- endif -%}
    </ul>
  </div>
  {%- endif -%}
</li>
{%- endif -%}

    </ul>
    {%- if block.settings.nav_contact_label != blank -%}
    <a href="{{ block.settings.nav_contact_url | default: '#' }}" class="fs-nav-contact"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>{{- block.settings.nav_contact_label | escape -}}</a>
    {%- endif -%}
  </div>
</nav>
</div>

<div class="fs-drawer" id="fs-drawer" aria-hidden="true">
  <div class="fs-drawer__overlay"></div>
  <div class="fs-drawer__panel">
    <div class="fs-drawer__head">
      <a href="{{ routes.root_url }}" class="fs-drawer__title">{{ shop.name }}</a>
      <button class="fs-drawer__close" aria-label="Close menu"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
    </div>
    <nav class="fs-drawer__nav" aria-label="Mobile navigation">

      {%- if block.settings.nav_1_label != blank -%}
      <div class="fs-drawer__item">
        <button class="fs-drawer__trigger">{{- block.settings.nav_1_label | escape -}}<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg></button>
        <div class="fs-drawer__sub">{%- for i in (1..4) -%}{%- assign l = 'nav_1_link_' | append: i | append: '_label' -%}{%- assign u = 'nav_1_link_' | append: i | append: '_url' -%}{%- if block.settings[l] != blank -%}<a href="{{ block.settings[u] | default: '#' }}" class="fs-drawer__sub-link">{{- block.settings[l] | escape -}}</a>{%- endif -%}{%- endfor -%}</div>
      </div>
      {%- endif -%}

      {%- if block.settings.nav_2_label != blank -%}
      <div class="fs-drawer__item">
        <button class="fs-drawer__trigger">{{- block.settings.nav_2_label | escape -}}<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg></button>
        <div class="fs-drawer__sub">{%- for i in (1..4) -%}{%- assign l = 'nav_2_link_' | append: i | append: '_label' -%}{%- assign u = 'nav_2_link_' | append: i | append: '_url' -%}{%- if block.settings[l] != blank -%}<a href="{{ block.settings[u] | default: '#' }}" class="fs-drawer__sub-link">{{- block.settings[l] | escape -}}</a>{%- endif -%}{%- endfor -%}</div>
      </div>
      {%- endif -%}

      {%- if block.settings.nav_3_label != blank -%}
      <div class="fs-drawer__item">
        <button class="fs-drawer__trigger">{{- block.settings.nav_3_label | escape -}}<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg></button>
        <div class="fs-drawer__sub">
          {%- for i in (1..4) -%}{%- assign l = 'nav_3_link_' | append: i | append: '_label' -%}{%- assign u = 'nav_3_link_' | append: i | append: '_url' -%}{%- if block.settings[l] != blank -%}<a href="{{ block.settings[u] | default: '#' }}" class="fs-drawer__sub-link">{{- block.settings[l] | escape -}}</a>{%- endif -%}{%- endfor -%}
          {%- if block.settings.nav_3_designer_link_1_label != blank -%}<a href="{{ block.settings.nav_3_designer_link_1_url | default: '#' }}" class="fs-drawer__sub-link" style="color:#6B4C8A">{{- block.settings.nav_3_designer_link_1_label | escape -}}</a>{%- endif -%}
          {%- if block.settings.nav_3_designer_link_2_label != blank -%}<a href="{{ block.settings.nav_3_designer_link_2_url | default: '#' }}" class="fs-drawer__sub-link" style="color:#6B4C8A">{{- block.settings.nav_3_designer_link_2_label | escape -}}</a>{%- endif -%}
        </div>
      </div>
      {%- endif -%}

      {%- if block.settings.nav_about_label != blank -%}
        {%- if has_about_sub -%}
        <div class="fs-drawer__item">
          <button class="fs-drawer__trigger">{{- block.settings.nav_about_label | escape -}}<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg></button>
          <div class="fs-drawer__sub">
            {%- if block.settings.nav_about_sub_1_label != blank -%}<a href="{{ block.settings.nav_about_sub_1_url | default: '#' }}" class="fs-drawer__sub-link">{{- block.settings.nav_about_sub_1_label | escape -}}</a>{%- endif -%}
            {%- if block.settings.nav_about_sub_2_label != blank -%}<a href="{{ block.settings.nav_about_sub_2_url | default: '#' }}" class="fs-drawer__sub-link">{{- block.settings.nav_about_sub_2_label | escape -}}</a>{%- endif -%}
            {%- if block.settings.nav_about_sub_3_label != blank -%}<a href="{{ block.settings.nav_about_sub_3_url | default: '#' }}" class="fs-drawer__sub-link">{{- block.settings.nav_about_sub_3_label | escape -}}</a>{%- endif -%}
          </div>
        </div>
        {%- else -%}
        <a href="{{ block.settings.nav_about_url | default: '#' }}" class="fs-drawer__plain-link">{{- block.settings.nav_about_label | escape -}}</a>
        {%- endif -%}
      {%- endif -%}

      {%- if block.settings.nav_contact_label != blank -%}
      <a href="{{ block.settings.nav_contact_url | default: '#' }}" class="fs-drawer__plain-link">{{- block.settings.nav_contact_label | escape -}}</a>
      {%- endif -%}

    </nav>
    <div class="fs-drawer__footer">
      <a href="{{ routes.account_url }}" class="fs-drawer__footer-link"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>{% if customer %}{{ customer.first_name }}'s account{% else %}Sign in{% endif %}</a>
      <a href="{{ routes.cart_url }}" class="fs-drawer__footer-link"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>Cart</a>
    </div>
  </div>
</div>


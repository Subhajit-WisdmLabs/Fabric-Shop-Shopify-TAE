{{ 'proof-strip.css' | asset_url | stylesheet_tag }}
<div class="ps-section" style="--ps-bg:{{ block.settings.bg }};--ps-border:{{ block.settings.bd }};--ps-key:{{ block.settings.kc }};--ps-val:{{ block.settings.vc }};"><div class="ps-inner"><div class="ps-item"><span class="ps-key">{{ block.settings.k1 | escape }}</span><span class="ps-val">{{ block.settings.v1 | escape }}</span></div><div class="ps-item"><span class="ps-key">{{ block.settings.k2 | escape }}</span><span class="ps-val">{{ block.settings.v2 | escape }}</span></div><div class="ps-item"><span class="ps-key">{{ block.settings.k3 | escape }}</span><span class="ps-val">{{ block.settings.v3 | escape }}</span></div></div></div>
{% schema %}
{"name":"Proof Strip","target":"section","settings":[
  {"type":"header","content":"Item 1"},
  {"type":"text","id":"k1","label":"Label","default":"Printed on demand"},
  {"type":"text","id":"v1","label":"Value","default":"Nothing is made before you order it."},
  {"type":"header","content":"Item 2"},
  {"type":"text","id":"k2","label":"Label","default":"By the metre"},
  {"type":"text","id":"v2","label":"Value","default":"One metre or one hundred. No minimums."},
  {"type":"header","content":"Item 3"},
  {"type":"text","id":"k3","label":"Label","default":"Shipped worldwide"},
  {"type":"text","id":"v3","label":"Value","default":"Duties shown at checkout. Door to door."},
  {"type":"color","id":"bg","label":"Background","default":"#FFFFFF"},
  {"type":"color","id":"bd","label":"Border","default":"#E8E3D8"},
  {"type":"color","id":"kc","label":"Label colour","default":"#5C7355"},
  {"type":"color","id":"vc","label":"Value colour","default":"#5C564A"}
]}
{% endschema %}

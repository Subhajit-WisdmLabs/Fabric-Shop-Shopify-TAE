{{ 'discovery-rail.css' | asset_url | stylesheet_tag }}

<style>
  #dr-{{ block.id }} {
    --dr-bg:           {{ block.settings.bg_color }};
    --dr-card-bg:      {{ block.settings.card_bg_color }};
    --dr-card-hover:   {{ block.settings.card_hover_color }};
    --dr-ink:          {{ block.settings.ink_color }};
    --dr-ink-soft:     {{ block.settings.ink_soft_color }};
    --dr-ink-mute:     {{ block.settings.ink_mute_color }};
    --dr-rule:         {{ block.settings.rule_color }};
  }
</style>

{%- liquid
  assign c1 = block.settings.card_1_collection
  assign c2 = block.settings.card_2_collection
  assign c3 = block.settings.card_3_collection
  assign c4 = block.settings.card_4_collection
  assign c5 = block.settings.card_5_collection
  assign c6 = block.settings.card_6_collection

  assign t1 = block.settings.card_1_tag
  assign t2 = block.settings.card_2_tag
  assign t3 = block.settings.card_3_tag
  assign t4 = block.settings.card_4_tag
  assign t5 = block.settings.card_5_tag
  assign t6 = block.settings.card_6_tag

  assign col_ids = ''
  if c1 != blank
    assign col_ids = col_ids | append: c1.id | append: ','
  endif
  if c2 != blank
    assign col_ids = col_ids | append: c2.id | append: ','
  endif
  if c3 != blank
    assign col_ids = col_ids | append: c3.id | append: ','
  endif
  if c4 != blank
    assign col_ids = col_ids | append: c4.id | append: ','
  endif
  if c5 != blank
    assign col_ids = col_ids | append: c5.id | append: ','
  endif
  if c6 != blank
    assign col_ids = col_ids | append: c6.id | append: ','
  endif
  assign col_ids = col_ids | remove_last: ','

  assign active_count = 0
  if c1 != blank
    assign active_count = active_count | plus: 1
  endif
  if c2 != blank
    assign active_count = active_count | plus: 1
  endif
  if c3 != blank
    assign active_count = active_count | plus: 1
  endif
  if c4 != blank
    assign active_count = active_count | plus: 1
  endif
  if c5 != blank
    assign active_count = active_count | plus: 1
  endif
  if c6 != blank
    assign active_count = active_count | plus: 1
  endif
-%}

<div class="dr-wrap" id="dr-{{ block.id }}">
  <div class="dr-inner">

    <div class="dr-head">
      {%- if block.settings.section_title != blank -%}
        <p class="dr-title">{{ block.settings.section_title | escape }}</p>
      {%- endif -%}
      {%- if block.settings.studios_url != blank -%}
        <a class="dr-link" href="{{ block.settings.studios_url }}" data-dr-studios-link>
          All studios →
        </a>
      {%- endif -%}
    </div>

    <div class="dr-track" data-dr-cols="{{ active_count }}">

      {%- if c1 != blank -%}
        <div class="dr-card dr-card--loading" data-dr-card="{{ c1.id }}" aria-busy="true">
          <div class="dr-thumbs"><div class="dr-thumb"></div><div class="dr-thumb"></div><div class="dr-thumb"></div></div>
          <div class="dr-tag">{{ t1 | escape }}</div>
          <div class="dr-name dr-skel dr-skel--name"></div>
          <div class="dr-meta dr-skel dr-skel--meta"></div>
        </div>
      {%- endif -%}

      {%- if c2 != blank -%}
        <div class="dr-card dr-card--loading" data-dr-card="{{ c2.id }}" aria-busy="true">
          <div class="dr-thumbs"><div class="dr-thumb"></div><div class="dr-thumb"></div><div class="dr-thumb"></div></div>
          <div class="dr-tag">{{ t2 | escape }}</div>
          <div class="dr-name dr-skel dr-skel--name"></div>
          <div class="dr-meta dr-skel dr-skel--meta"></div>
        </div>
      {%- endif -%}

      {%- if c3 != blank -%}
        <div class="dr-card dr-card--loading" data-dr-card="{{ c3.id }}" aria-busy="true">
          <div class="dr-thumbs"><div class="dr-thumb"></div><div class="dr-thumb"></div><div class="dr-thumb"></div></div>
          <div class="dr-tag">{{ t3 | escape }}</div>
          <div class="dr-name dr-skel dr-skel--name"></div>
          <div class="dr-meta dr-skel dr-skel--meta"></div>
        </div>
      {%- endif -%}

      {%- if c4 != blank -%}
        <div class="dr-card dr-card--loading" data-dr-card="{{ c4.id }}" aria-busy="true">
          <div class="dr-thumbs"><div class="dr-thumb"></div><div class="dr-thumb"></div><div class="dr-thumb"></div></div>
          <div class="dr-tag">{{ t4 | escape }}</div>
          <div class="dr-name dr-skel dr-skel--name"></div>
          <div class="dr-meta dr-skel dr-skel--meta"></div>
        </div>
      {%- endif -%}

      {%- if c5 != blank -%}
        <div class="dr-card dr-card--loading" data-dr-card="{{ c5.id }}" aria-busy="true">
          <div class="dr-thumbs"><div class="dr-thumb"></div><div class="dr-thumb"></div><div class="dr-thumb"></div></div>
          <div class="dr-tag">{{ t5 | escape }}</div>
          <div class="dr-name dr-skel dr-skel--name"></div>
          <div class="dr-meta dr-skel dr-skel--meta"></div>
        </div>
      {%- endif -%}

      {%- if c6 != blank -%}
        <div class="dr-card dr-card--loading" data-dr-card="{{ c6.id }}" aria-busy="true">
          <div class="dr-thumbs"><div class="dr-thumb"></div><div class="dr-thumb"></div><div class="dr-thumb"></div></div>
          <div class="dr-tag">{{ t6 | escape }}</div>
          <div class="dr-name dr-skel dr-skel--name"></div>
          <div class="dr-meta dr-skel dr-skel--meta"></div>
        </div>
      {%- endif -%}

    </div>

  </div>
</div>

{%- if col_ids != blank -%}
<script>
(function () {
  var wrap = document.getElementById('dr-{{ block.id }}');
  if (!wrap) return;

  var cardEls = wrap.querySelectorAll('[data-dr-card]');
  if (!cardEls.length) return;

  fetch('/apps/fabric-shop/api/discovery-rail?collections={{ col_ids | url_encode }}')
    .then(function (r) { return r.ok ? r.json() : null; })
    .then(function (data) {
      if (!data) return;

      var linkEl = wrap.querySelector('[data-dr-studios-link]');
      if (linkEl && data.studioCount) {
        linkEl.textContent = 'All ' + data.studioCount + ' studios →';
      }

      if (!data.cards || !data.cards.length) return;

      var cardMap = {};
      data.cards.forEach(function (c) { cardMap[String(c.collectionId)] = c; });

      cardEls.forEach(function (cardEl) {
        var colId = cardEl.getAttribute('data-dr-card');
        var c = cardMap[colId];
        if (!c) return;

        var thumbEls = cardEl.querySelectorAll('.dr-thumb');
        thumbEls.forEach(function (thumb, i) {
          if (c.thumbs[i]) {
            thumb.style.backgroundImage = 'url("' + c.thumbs[i] + '")';
          }
        });

        var nameEl = cardEl.querySelector('.dr-name');
        if (nameEl) {
          nameEl.classList.remove('dr-skel', 'dr-skel--name');
          nameEl.textContent = c.studioName;
        }

        var metaEl = cardEl.querySelector('.dr-meta');
        if (metaEl) {
          metaEl.classList.remove('dr-skel', 'dr-skel--meta');
          metaEl.textContent = c.fullName + ' · ' + c.city + ' · ' + c.designCount + ' designs';
        }

        cardEl.classList.remove('dr-card--loading');
        cardEl.removeAttribute('aria-busy');
      });
    })
    .catch(function () { /* keep skeleton on error */ });
})();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Discovery Rail",
  "target": "section",
  "settings": [
    { "type": "header", "content": "Section" },
    {
      "type": "text",
      "id": "section_title",
      "label": "Title",
      "default": "Start with a studio."
    },
    {
      "type": "url",
      "id": "studios_url",
      "label": "All studios link"
    },

    { "type": "header", "content": "Card 1" },
    { "type": "collection", "id": "card_1_collection", "label": "Studio collection" },
    { "type": "text", "id": "card_1_tag", "label": "Tag label", "default": "Featured studio" },

    { "type": "header", "content": "Card 2" },
    { "type": "collection", "id": "card_2_collection", "label": "Studio collection" },
    { "type": "text", "id": "card_2_tag", "label": "Tag label", "default": "New this week" },

    { "type": "header", "content": "Card 3" },
    { "type": "collection", "id": "card_3_collection", "label": "Studio collection" },
    { "type": "text", "id": "card_3_tag", "label": "Tag label", "default": "Editor's pick" },

    { "type": "header", "content": "Card 4" },
    { "type": "collection", "id": "card_4_collection", "label": "Studio collection" },
    { "type": "text", "id": "card_4_tag", "label": "Tag label", "default": "Trending" },

    { "type": "header", "content": "Card 5 (optional)" },
    { "type": "collection", "id": "card_5_collection", "label": "Studio collection" },
    { "type": "text", "id": "card_5_tag", "label": "Tag label", "default": "" },

    { "type": "header", "content": "Card 6 (optional)" },
    { "type": "collection", "id": "card_6_collection", "label": "Studio collection" },
    { "type": "text", "id": "card_6_tag", "label": "Tag label", "default": "" },

    { "type": "header", "content": "Colours" },
    { "type": "color", "id": "bg_color",        "label": "Background",      "default": "#FFFFFF" },
    { "type": "color", "id": "card_bg_color",    "label": "Card background", "default": "#FAF8F3" },
    { "type": "color", "id": "card_hover_color", "label": "Card hover",      "default": "#F4F1EA" },
    { "type": "color", "id": "ink_color",        "label": "Studio name",     "default": "#1A1814" },
    { "type": "color", "id": "ink_soft_color",   "label": "Meta text",       "default": "#5C564A" },
    { "type": "color", "id": "ink_mute_color",   "label": "Tag label",       "default": "#9A9285" },
    { "type": "color", "id": "rule_color",       "label": "Card border",     "default": "#E8E3D8" }
  ]
}
{% endschema %}

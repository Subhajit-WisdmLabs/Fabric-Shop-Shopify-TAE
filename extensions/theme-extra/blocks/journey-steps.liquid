{{ 'journey-steps.css' | asset_url | stylesheet_tag }}

<div class="tmk-wrap">

  <!-- Section header -->
  <div class="tmk-head">
    <div class="tmk-head-inner">
      {%- if block.settings.eyebrow != blank -%}
        <p class="tmk-eyebrow">{{ block.settings.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if block.settings.title != blank -%}
        <h2 class="tmk-title">{{ block.settings.title | remove: '<p>' | remove: '</p>' }}</h2>
      {%- endif -%}
      {%- if block.settings.sub != blank -%}
        <p class="tmk-sub">{{ block.settings.sub | escape }}</p>
      {%- endif -%}
    </div>
  </div>

  <!-- Steps 1–5 (hidden if headline is blank) -->
  {%- for i in (1..5) -%}
    {%- assign hl_key  = 'step_' | append: i | append: '_headline' -%}
    {%- assign bd_key  = 'step_' | append: i | append: '_body' -%}
    {%- assign alt_key = 'step_' | append: i | append: '_alt_bg' -%}
    {%- assign l1t_key = 'step_' | append: i | append: '_link_1_text' -%}
    {%- assign l1u_key = 'step_' | append: i | append: '_link_1_url' -%}
    {%- assign l1s_key = 'step_' | append: i | append: '_link_1_style' -%}
    {%- assign l2t_key = 'step_' | append: i | append: '_link_2_text' -%}
    {%- assign l2u_key = 'step_' | append: i | append: '_link_2_url' -%}
    {%- assign l2s_key = 'step_' | append: i | append: '_link_2_style' -%}
    {%- assign step_hl = block.settings[hl_key] -%}
    {%- if step_hl != blank -%}
      <div class="tmk-step{% if block.settings[alt_key] %} tmk-step--alt{% endif %}">
        <div class="tmk-step-inner">

          <div class="tmk-step-num" aria-hidden="true">
            {%- if i < 10 -%}0{%- endif -%}{{ i }}
          </div>

          <div class="tmk-step-main">
            <h3 class="tmk-step-headline">
              {{- step_hl | remove: '<p>' | remove: '</p>' -}}
            </h3>

            {%- assign step_bd = block.settings[bd_key] -%}
            {%- if step_bd != blank -%}
              <p class="tmk-step-body">{{ step_bd | escape }}</p>
            {%- endif -%}

            {%- assign l1t = block.settings[l1t_key] -%}
            {%- assign l2t = block.settings[l2t_key] -%}
            {%- if l1t != blank or l2t != blank -%}
              <div class="tmk-step-links">
                {%- if l1t != blank -%}
                  <a href="{{ block.settings[l1u_key] | default: '#' }}"
                     class="tmk-step-link{% if block.settings[l1s_key] == 'rust' %} tmk-step-link--rust{% endif %}">
                    {{- l1t | escape -}}
                  </a>
                {%- endif -%}
                {%- if l2t != blank -%}
                  <a href="{{ block.settings[l2u_key] | default: '#' }}"
                     class="tmk-step-link{% if block.settings[l2s_key] == 'rust' %} tmk-step-link--rust{% endif %}">
                    {{- l2t | escape -}}
                  </a>
                {%- endif -%}
              </div>
            {%- endif -%}

          </div>
        </div>
      </div>
    {%- endif -%}
  {%- endfor -%}

</div>

{% schema %}
{
  "name": "Journey Steps",
  "target": "section",
  "settings": [
    { "type": "header", "content": "Section header" },
    { "type": "text",     "id": "eyebrow", "label": "Eyebrow",   "default": "The make" },
    { "type": "richtext", "id": "title",   "label": "Title",     "default": "<p>Five steps, from your order <em>to your door</em>.</p>" },
    { "type": "textarea", "id": "sub",     "label": "Sub text",  "default": "Whichever way in you choose, your order is made the same way. Here is what happens, step by step." },

    { "type": "header", "content": "Step 1" },
    { "type": "richtext", "id": "step_1_headline",    "label": "Headline",      "default": "<p><em>You</em> choose.</p>" },
    { "type": "textarea", "id": "step_1_body",         "label": "Body",          "default": "Pick a design — an original Partner print, your own artwork, or a stocked fabric from The Yard — then choose your base fabric and your length, down to the metre. On PrintLab and Custom upload, a live preview shows your print on screen before you order." },
    { "type": "checkbox", "id": "step_1_alt_bg",       "label": "Linen background", "default": false },
    { "type": "text",     "id": "step_1_link_1_text",  "label": "Link 1 — text", "default": "Want to feel a base or test a print first? Order a swatch →" },
    { "type": "url",      "id": "step_1_link_1_url",   "label": "Link 1 — URL" },
    { "type": "select",   "id": "step_1_link_1_style", "label": "Link 1 — style", "options": [{ "value": "sage", "label": "Sage" }, { "value": "rust", "label": "Rust" }], "default": "rust" },
    { "type": "text",     "id": "step_1_link_2_text",  "label": "Link 2 — text" },
    { "type": "url",      "id": "step_1_link_2_url",   "label": "Link 2 — URL" },
    { "type": "select",   "id": "step_1_link_2_style", "label": "Link 2 — style", "options": [{ "value": "sage", "label": "Sage" }, { "value": "rust", "label": "Rust" }], "default": "sage" },

    { "type": "header", "content": "Step 2" },
    { "type": "richtext", "id": "step_2_headline",    "label": "Headline",      "default": "<p><em>We</em> confirm.</p>" },
    { "type": "textarea", "id": "step_2_body",         "label": "Body",          "default": "Your order is confirmed by email and queued for the make. If you've uploaded your own artwork, the file's format and size are checked automatically at upload — so anything that needs adjusting is flagged before a metre is printed." },
    { "type": "checkbox", "id": "step_2_alt_bg",       "label": "Linen background", "default": true },
    { "type": "text",     "id": "step_2_link_1_text",  "label": "Link 1 — text", "default": "File setup, colour, and resolution are covered in the FAQs →" },
    { "type": "url",      "id": "step_2_link_1_url",   "label": "Link 1 — URL" },
    { "type": "select",   "id": "step_2_link_1_style", "label": "Link 1 — style", "options": [{ "value": "sage", "label": "Sage" }, { "value": "rust", "label": "Rust" }], "default": "sage" },
    { "type": "text",     "id": "step_2_link_2_text",  "label": "Link 2 — text", "default": "Something specific? Contact us — we reply within 24 hours →" },
    { "type": "url",      "id": "step_2_link_2_url",   "label": "Link 2 — URL" },
    { "type": "select",   "id": "step_2_link_2_style", "label": "Link 2 — style", "options": [{ "value": "sage", "label": "Sage" }, { "value": "rust", "label": "Rust" }], "default": "sage" },

    { "type": "header", "content": "Step 3" },
    { "type": "richtext", "id": "step_3_headline",    "label": "Headline",      "default": "<p>We print, <em>on demand</em>.</p>" },
    { "type": "textarea", "id": "step_3_body",         "label": "Body",          "default": "Your fabric is printed to your length on the base you chose — nothing is printed until you order it, so nothing is made that isn't wanted. Ordering from The Yard? There's no print step: your fabric is cut to length from stock and moves straight to the check." },
    { "type": "checkbox", "id": "step_3_alt_bg",       "label": "Linen background", "default": false },
    { "type": "text",     "id": "step_3_link_1_text",  "label": "Link 1 — text", "default": "How each base prints — the two methods, below →" },
    { "type": "url",      "id": "step_3_link_1_url",   "label": "Link 1 — URL" },
    { "type": "select",   "id": "step_3_link_1_style", "label": "Link 1 — style", "options": [{ "value": "sage", "label": "Sage" }, { "value": "rust", "label": "Rust" }], "default": "sage" },
    { "type": "text",     "id": "step_3_link_2_text",  "label": "Link 2 — text" },
    { "type": "url",      "id": "step_3_link_2_url",   "label": "Link 2 — URL" },
    { "type": "select",   "id": "step_3_link_2_style", "label": "Link 2 — style", "options": [{ "value": "sage", "label": "Sage" }, { "value": "rust", "label": "Rust" }], "default": "sage" },

    { "type": "header", "content": "Step 4" },
    { "type": "richtext", "id": "step_4_headline",    "label": "Headline",      "default": "<p>We check, <em>every metre</em>.</p>" },
    { "type": "textarea", "id": "step_4_body",         "label": "Body",          "default": "Before anything ships, your order is inspected end to end — print quality, fabric faults, repeat alignment. Anything that doesn't pass is reprinted, not shipped. It's the same standard we held supplying the trade for twenty years." },
    { "type": "checkbox", "id": "step_4_alt_bg",       "label": "Linen background", "default": true },
    { "type": "text",     "id": "step_4_link_1_text",  "label": "Link 1 — text", "default": "And if something's not right when it arrives, the claims process is in the FAQs →" },
    { "type": "url",      "id": "step_4_link_1_url",   "label": "Link 1 — URL" },
    { "type": "select",   "id": "step_4_link_1_style", "label": "Link 1 — style", "options": [{ "value": "sage", "label": "Sage" }, { "value": "rust", "label": "Rust" }], "default": "sage" },
    { "type": "text",     "id": "step_4_link_2_text",  "label": "Link 2 — text" },
    { "type": "url",      "id": "step_4_link_2_url",   "label": "Link 2 — URL" },
    { "type": "select",   "id": "step_4_link_2_style", "label": "Link 2 — style", "options": [{ "value": "sage", "label": "Sage" }, { "value": "rust", "label": "Rust" }], "default": "sage" },

    { "type": "header", "content": "Step 5" },
    { "type": "richtext", "id": "step_5_headline",    "label": "Headline",      "default": "<p>It <em>ships</em>.</p>" },
    { "type": "textarea", "id": "step_5_body",         "label": "Body",          "default": "Your order is printed, checked, and packed within 7–10 business days, then shipped worldwide — 10–18 business days in transit, tracked door to door. Duties and taxes are shown at checkout, so the price you see is the price you pay." },
    { "type": "checkbox", "id": "step_5_alt_bg",       "label": "Linen background", "default": false },
    { "type": "text",     "id": "step_5_link_1_text",  "label": "Link 1 — text", "default": "Shipping times, tracking, and delivery detail, in the FAQs →" },
    { "type": "url",      "id": "step_5_link_1_url",   "label": "Link 1 — URL" },
    { "type": "select",   "id": "step_5_link_1_style", "label": "Link 1 — style", "options": [{ "value": "sage", "label": "Sage" }, { "value": "rust", "label": "Rust" }], "default": "sage" },
    { "type": "text",     "id": "step_5_link_2_text",  "label": "Link 2 — text" },
    { "type": "url",      "id": "step_5_link_2_url",   "label": "Link 2 — URL" },
    { "type": "select",   "id": "step_5_link_2_style", "label": "Link 2 — style", "options": [{ "value": "sage", "label": "Sage" }, { "value": "rust", "label": "Rust" }], "default": "sage" }
  ]
}
{% endschema %}

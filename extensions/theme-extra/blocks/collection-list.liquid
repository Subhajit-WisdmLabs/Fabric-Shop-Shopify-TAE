{{ 'collection-list.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign is_carousel = false
  if block.settings.layout == 'carousel'
    assign is_carousel = true
  endif
  assign circle_image = block.settings.circle_image
  assign columns      = block.settings.columns
-%}

<style>
  #cl-{{ block.id }} {
    --cl-bg:               {{ block.settings.bg_color }};
    --cl-eyebrow-color:    {{ block.settings.eyebrow_color }};
    --cl-heading-size:     {{ block.settings.heading_size }}px;
    --cl-heading-color:    {{ block.settings.heading_color }};
    --cl-subtitle-color:   {{ block.settings.subtitle_color }};
    --cl-browse-color:     {{ block.settings.browse_color }};
    --cl-card-title-color: {{ block.settings.card_title_color }};
  }
</style>

<div class="cl-wrap" id="cl-{{ block.id }}">
  <div class="cl-inner">

    <div class="cl-header">
      <div class="cl-header__left">
        {%- if block.settings.eyebrow != blank -%}
          <p class="cl-eyebrow">{{ block.settings.eyebrow | escape }}</p>
        {%- endif -%}
        {%- if block.settings.heading != blank -%}
          <h2 class="cl-heading">{{ block.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if block.settings.subtitle != blank -%}
          <p class="cl-subtitle">{{ block.settings.subtitle | escape }}</p>
        {%- endif -%}
      </div>
      {%- if block.settings.browse_label != blank -%}
        <a href="{{ block.settings.browse_url | default: '#' }}" class="cl-browse">
          {{ block.settings.browse_label | escape }} →
        </a>
      {%- endif -%}
    </div>

    <div class="cl-grid cl-grid--{{ block.settings.layout }} cl-grid--cols-{{ columns }}"
         id="cl-grid-{{ block.id }}"
         data-columns="{{ columns }}">

      {%- for i in (1..6) -%}
        {%- assign slug_key = "slug_" | append: i -%}
        {%- assign img_key  = "image_" | append: i -%}
        {%- assign slug     = block.settings[slug_key] -%}
        {%- assign img_ov   = block.settings[img_key] -%}

        {%- if slug != blank -%}
          <a class="cl-card cl-card--pending" data-slug="{{ slug | escape }}"{% if img_ov != blank %} data-image-set="1"{% endif %}>
            <div class="cl-card__img-wrap{% if circle_image %} cl-card__img-wrap--circle{% endif %}">
              {%- if img_ov != blank -%}
                {{ img_ov | image_url: width: 600 | image_tag: loading: 'lazy', class: 'cl-card__img', alt: '' }}
              {%- else -%}
                <div class="cl-card__img-placeholder"></div>
              {%- endif -%}
            </div>
            <div class="cl-card__info">
              <span class="cl-card__title"></span>
              <span class="cl-card__partner"></span>
              <span class="cl-card__count"></span>
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}

    </div>

    {%- if is_carousel -%}
      <div class="cl-arrows" id="cl-arrows-{{ block.id }}" hidden>
        <button type="button" class="cl-arrow cl-arrow--prev" aria-label="Previous">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>
        <button type="button" class="cl-arrow cl-arrow--next" aria-label="Next">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      </div>
    {%- endif -%}

  </div>
</div>

<script>
(function () {
  var wrap = document.getElementById('cl-{{ block.id }}');
  if (!wrap) return;

  var grid  = document.getElementById('cl-grid-{{ block.id }}');
  var cards = grid.querySelectorAll('.cl-card[data-slug]');

  /* ── Fetch data for each card ──────────────────────────────── */
  cards.forEach(function (card) {
    var slug = card.dataset.slug;
    fetch('/apps/fabric-shop/api/collection-search?handle=' + encodeURIComponent(slug))
      .then(function (r) { return r.json(); })
      .then(function (data) {
        var result = data.results && data.results[0];
        if (!result) { card.style.display = 'none'; return; }

        card.href = '/pages/partners?handle=' + encodeURIComponent(result.partnerSlug)
                  + '&tab=collection&slug=' + encodeURIComponent(result.handle);

        var titleEl   = card.querySelector('.cl-card__title');
        var partnerEl = card.querySelector('.cl-card__partner');
        var countEl   = card.querySelector('.cl-card__count');
        if (titleEl)   titleEl.textContent   = result.title;
        if (partnerEl) partnerEl.textContent  = result.partnerName;
        if (countEl)   countEl.textContent    = result.productsCount + ' designs';

        if (!card.dataset.imageSet && result.image) {
          var placeholder = card.querySelector('.cl-card__img-placeholder');
          if (placeholder) {
            var img = document.createElement('img');
            img.src       = result.image;
            img.className = 'cl-card__img';
            img.loading   = 'lazy';
            img.alt       = result.title;
            placeholder.replaceWith(img);
          }
        }

        card.classList.remove('cl-card--pending');
      })
      .catch(function () { card.style.display = 'none'; });
  });

  {%- if is_carousel -%}
  /* ── Carousel arrows ───────────────────────────────────────── */
  var arrowsEl = document.getElementById('cl-arrows-{{ block.id }}');
  if (!arrowsEl) return;

  var prevBtn = arrowsEl.querySelector('.cl-arrow--prev');
  var nextBtn = arrowsEl.querySelector('.cl-arrow--next');
  var cols    = parseInt(grid.dataset.columns, 10) || 4;
  var count   = grid.querySelectorAll('.cl-card[data-slug]').length;

  if (count > cols) arrowsEl.removeAttribute('hidden');

  function syncPulse() {
    [prevBtn, nextBtn].forEach(function(b) { b.style.animationName = 'none'; });
    requestAnimationFrame(function() {
      requestAnimationFrame(function() {
        [prevBtn, nextBtn].forEach(function(b) { b.style.animationName = ''; });
      });
    });
  }
  syncPulse();

  function cardWidth() {
    var c = grid.querySelector('.cl-card');
    if (!c) return 240;
    var gap = parseFloat(window.getComputedStyle(grid).gap) || 16;
    return c.offsetWidth + gap;
  }

  function atStart() { return grid.scrollLeft <= 4; }
  function atEnd()   { return grid.scrollLeft >= grid.scrollWidth - grid.clientWidth - 4; }

  function scrollNext() {
    atEnd()
      ? grid.scrollTo({ left: 0, behavior: 'smooth' })
      : grid.scrollBy({ left: cardWidth(), behavior: 'smooth' });
  }
  function scrollPrev() {
    atStart()
      ? grid.scrollTo({ left: grid.scrollWidth, behavior: 'smooth' })
      : grid.scrollBy({ left: -cardWidth(), behavior: 'smooth' });
  }

  nextBtn.addEventListener('click', scrollNext);
  prevBtn.addEventListener('click', scrollPrev);

  function updateArrows() {
    var prevWas = prevBtn.classList.contains('cl-arrow--disabled');
    var nextWas = nextBtn.classList.contains('cl-arrow--disabled');
    prevBtn.classList.toggle('cl-arrow--disabled', atStart());
    nextBtn.classList.toggle('cl-arrow--disabled', atEnd());
    if ((prevWas && !prevBtn.classList.contains('cl-arrow--disabled')) ||
        (nextWas && !nextBtn.classList.contains('cl-arrow--disabled'))) {
      syncPulse();
    }
  }
  grid.addEventListener('scroll', updateArrows, { passive: true });
  updateArrows();
  {%- endif -%}
}());
</script>

{% schema %}
{
  "name": "Collection List",
  "target": "section",
  "settings": [
    { "type": "header",   "content": "Section" },
    { "type": "color",    "id": "bg_color",      "label": "Background colour", "default": "#FAF8F3" },
    { "type": "text",     "id": "eyebrow",        "label": "Eyebrow text",     "default": "Shop by category" },
    { "type": "color",    "id": "eyebrow_color",  "label": "Eyebrow colour",   "default": "#8B8580" },
    { "type": "text",     "id": "heading",        "label": "Heading",          "default": "Browse Collections" },
    { "type": "range",    "id": "heading_size",   "label": "Heading font size","min": 24, "max": 56, "step": 2, "unit": "px", "default": 36 },
    { "type": "color",    "id": "heading_color",  "label": "Heading colour",   "default": "#1A1814" },
    { "type": "text",     "id": "subtitle",       "label": "Subtitle" },
    { "type": "color",    "id": "subtitle_color", "label": "Subtitle colour",  "default": "#6B6560" },

    { "type": "header",   "content": "Layout" },
    {
      "type": "select", "id": "layout", "label": "Layout",
      "options": [
        { "value": "carousel", "label": "Carousel" },
        { "value": "grid",     "label": "Grid" }
      ],
      "default": "carousel"
    },
    {
      "type": "select", "id": "columns", "label": "Columns",
      "options": [
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns" },
        { "value": "5", "label": "5 columns" },
        { "value": "6", "label": "6 columns" }
      ],
      "default": "4"
    },
    { "type": "checkbox", "id": "circle_image", "label": "Circle images", "default": false },

    { "type": "header", "content": "Browse Link" },
    { "type": "text",  "id": "browse_label", "label": "Link label",  "default": "View all collections" },
    { "type": "url",   "id": "browse_url",   "label": "Link URL" },
    { "type": "color", "id": "browse_color", "label": "Link colour", "default": "#1A1814" },

    { "type": "header", "content": "Cards" },
    { "type": "color", "id": "card_title_color", "label": "Title colour", "default": "#1A1814" },

    { "type": "header", "content": "Collections", "info": "Enter the Shopify collection handle (e.g. summer-2026). Title, image, and partner URL are resolved automatically." },
    { "type": "text",         "id": "slug_1", "label": "Collection handle 1" },
    { "type": "image_picker", "id": "image_1", "label": "Image override 1", "info": "Optional — replaces the API image" },
    { "type": "text",         "id": "slug_2", "label": "Collection handle 2" },
    { "type": "image_picker", "id": "image_2", "label": "Image override 2" },
    { "type": "text",         "id": "slug_3", "label": "Collection handle 3" },
    { "type": "image_picker", "id": "image_3", "label": "Image override 3" },
    { "type": "text",         "id": "slug_4", "label": "Collection handle 4" },
    { "type": "image_picker", "id": "image_4", "label": "Image override 4" },
    { "type": "text",         "id": "slug_5", "label": "Collection handle 5" },
    { "type": "image_picker", "id": "image_5", "label": "Image override 5" },
    { "type": "text",         "id": "slug_6", "label": "Collection handle 6" },
    { "type": "image_picker", "id": "image_6", "label": "Image override 6" }
  ]
}
{% endschema %}
